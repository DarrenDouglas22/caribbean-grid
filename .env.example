# Copy to `.env` and fill in. `.env` is gitignored — never commit it.
#
# Backend: Neon Postgres + serverless API (see README "Deploy").

# The Neon connection string. Used by:
#   - the serverless API functions at runtime (set this in the Vercel dashboard)
#   - the local ingest/composer/migrate scripts
# Get it from the Neon dashboard -> Connection Details.
DATABASE_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Where the frontend finds the API. "/api" when the static site and the
# serverless functions share an origin on Vercel (the default). Set an absolute
# URL only if the static site is hosted separately from the functions.
VITE_API_URL=/api

# Optional: restrict CORS to your site origin (defaults to * — the endpoints
# expose no secrets and never return the answer corpus).
# ALLOW_ORIGIN=https://your-app.vercel.app
