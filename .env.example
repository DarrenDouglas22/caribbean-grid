# Copy to `.env` and fill in. `.env` is gitignored (KTD3) — never commit it.
#
# The ANON key is public by design: it ships in the client bundle, and RLS +
# security-definer RPCs are the protection (KTD2). It is safe to expose.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The SERVICE key bypasses RLS entirely. It is used only by the local ingest
# and composer scripts (KTD3). NEVER commit it, never put it in the client
# bundle, never expose it to the browser. Keep it in `.env` only.
SUPABASE_SERVICE_KEY=your-service-role-key
